<?xml version="1.0" encoding="utf-8"?>
<!-- Gold "spotlight" highlight drawn behind the active player's seat. Its alpha is
     pulsed at runtime (see CardPairLayout) so the glow breathes while it's their turn. -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="14dp" />
            <solid android:color="#33FFD24A" />
            <stroke
                android:width="2dp"
                android:color="@color/tableGold" />
        </shape>
    </item>
</layer-list>
