<?xml version="1.0" encoding="utf-8"?>
<!-- Casino "DEALER" button: cream disc with a raised highlight and gold ring. -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="oval">
            <gradient
                android:type="radial"
                android:gradientRadius="70%"
                android:centerX="0.35"
                android:centerY="0.3"
                android:startColor="#FFFFFF"
                android:endColor="#E0DAC8" />
            <stroke
                android:width="1.5dp"
                android:color="@color/tableGoldDeep" />
        </shape>
    </item>
</layer-list>
