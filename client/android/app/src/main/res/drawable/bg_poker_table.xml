<?xml version="1.0" encoding="utf-8"?>
<!-- Layered poker table: wooden rail -> gold trim -> felt with a lit centre. -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Outer wooden rail -->
    <item>
        <shape android:shape="oval">
            <gradient
                android:type="linear"
                android:angle="90"
                android:startColor="@color/railBrownLight"
                android:endColor="@color/railBrownDark" />
            <stroke
                android:width="1dp"
                android:color="#1A0E06" />
        </shape>
    </item>

    <!-- Thin gold trim between rail and felt -->
    <item
        android:bottom="12dp"
        android:left="12dp"
        android:right="12dp"
        android:top="12dp">
        <shape android:shape="oval">
            <solid android:color="@color/tableGoldDeep" />
        </shape>
    </item>

    <!-- Felt: radial gradient so the centre reads as lit under a lamp -->
    <item
        android:bottom="16dp"
        android:left="16dp"
        android:right="16dp"
        android:top="16dp">
        <shape android:shape="oval">
            <gradient
                android:type="radial"
                android:gradientRadius="65%"
                android:centerX="0.5"
                android:centerY="0.5"
                android:startColor="@color/feltGreenLight"
                android:centerColor="@color/feltGreenMid"
                android:endColor="@color/feltGreenDark" />
            <stroke
                android:width="2dp"
                android:color="#0B3318" />
        </shape>
    </item>

    <!-- Faint inner betting-line ring -->
    <item
        android:bottom="48dp"
        android:left="48dp"
        android:right="48dp"
        android:top="48dp">
        <shape android:shape="oval">
            <solid android:color="@android:color/transparent" />
            <stroke
                android:width="1dp"
                android:color="#33FFFFFF" />
        </shape>
    </item>

</layer-list>
