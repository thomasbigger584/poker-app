<?xml version="1.0" encoding="utf-8"?>
<!-- Inset readout that shows the running bet amount. -->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <gradient
        android:angle="270"
        android:startColor="#CC081D0E"
        android:endColor="#E6041209" />
    <corners android:radius="12dp" />
    <stroke
        android:width="1dp"
        android:color="@color/tableGold" />
</shape>
