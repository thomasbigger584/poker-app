<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<databaseChangeLog xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" logicalFilePath="db.changelog-1.0.xml"
                   xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-3.4.xsd">

    <changeSet author="tbigg" id="1">
        <createTable tableName="persona">
            <column name="id" type="uuid">
                <constraints nullable="false"/>
            </column>
            <column name="name" type="text">
                <constraints nullable="false"/>
            </column>
            <column name="instructions" type="text"/>
            <column name="created_date_time" type="TIMESTAMP WITH TIME ZONE">
                <constraints nullable="false"/>
            </column>
            <column name="modified_date_time" type="TIMESTAMP WITH TIME ZONE">
                <constraints nullable="false"/>
            </column>
        </createTable>
        <addPrimaryKey columnNames="id" constraintName="pk_persona" tableName="persona"/>

        <createTable tableName="app_user">
            <column name="id" type="uuid">
                <constraints nullable="false"/>
            </column>
            <column name="username" type="text">
                <constraints nullable="false"/>
            </column>
            <column name="first_name" type="text"/>
            <column name="last_name" type="text"/>
            <column name="total_funds" type="decimal(19,2)" defaultValueNumeric="0">
                <constraints nullable="false"/>
            </column>
            <column name="enabled" type="boolean" defaultValue="0">
                <constraints nullable="false"/>
            </column>
            <column name="created_date_time" type="TIMESTAMP WITH TIME ZONE">
                <constraints nullable="false"/>
            </column>
            <column name="modified_date_time" type="TIMESTAMP WITH TIME ZONE">
                <constraints nullable="false"/>
            </column>
        </createTable>
        <addPrimaryKey columnNames="id" constraintName="pk_app_user" tableName="app_user"/>

        <createTable tableName="physical_user">
            <column name="id" type="uuid">
                <constraints nullable="false"/>
            </column>
            <column name="email" type="text"/>
            <column name="email_verified" type="boolean" defaultValue="0">
                <constraints nullable="false"/>
            </column>
            <column name="groups" type="jsonb"/>
        </createTable>
        <addPrimaryKey columnNames="id" constraintName="pk_physical_user" tableName="physical_user"/>
        <addForeignKeyConstraint constraintName="fk_physical_user_id"
                                 baseTableName="physical_user" baseColumnNames="id"
                                 referencedTableName="app_user" referencedColumnNames="id"
                                 onDelete="CASCADE"/>

        <createTable tableName="bot_user">
            <column name="id" type="uuid">
                <constraints nullable="false"/>
            </column>
            <column name="persona_id" type="uuid">
                <constraints nullable="false"/>
            </column>
        </createTable>
        <addPrimaryKey columnNames="id" constraintName="pk_bot_user" tableName="bot_user"/>
        <addForeignKeyConstraint constraintName="fk_bot_user_id"
                                 baseTableName="bot_user" baseColumnNames="id"
                                 referencedTableName="app_user" referencedColumnNames="id"
                                 onDelete="CASCADE"/>
        <addForeignKeyConstraint constraintName="fk_bot_user_persona_id"
                                 baseTableName="bot_user" baseColumnNames="persona_id"
                                 referencedTableName="persona" referencedColumnNames="id"/>
    </changeSet>

    <changeSet author="tbigg" id="2">
        <createTable tableName="poker_table">
            <column name="id" type="uuid">
                <constraints nullable="false"/>
            </column>
            <column name="name" type="text">
                <constraints nullable="false"/>
            </column>
            <column name="game_type" type="text">
                <constraints nullable="false"/>
            </column>
            <column name="speed_multiplier" type="double"/>
            <column name="total_rounds" type="int"/>
            <column name="min_players" type="int">
                <constraints nullable="false"/>
            </column>
            <column name="max_players" type="int">
                <constraints nullable="false"/>
            </column>
            <column name="min_buyin" type="decimal(19,2)">
                <constraints nullable="false"/>
            </column>
            <column name="max_buyin" type="decimal(19,2)">
                <constraints nullable="false"/>
            </column>
            <column name="created_date_time" type="TIMESTAMP WITH TIME ZONE">
                <constraints nullable="false"/>
            </column>
            <column name="modified_date_time" type="TIMESTAMP WITH TIME ZONE">
                <constraints nullable="false"/>
            </column>
        </createTable>
        <addPrimaryKey columnNames="id" constraintName="pk_poker_table" tableName="poker_table"/>
    </changeSet>

    <changeSet author="tbigg" id="3">
        <createTable tableName="round">
            <column name="id" type="uuid">
                <constraints nullable="false"/>
            </column>
            <column name="poker_table_id" type="uuid">
                <constraints nullable="false"/>
            </column>
            <column name="round_state" type="text" defaultValue="WAITING_FOR_PLAYERS">
                <constraints nullable="false"/>
            </column>
            <column name="created_date_time" type="TIMESTAMP WITH TIME ZONE">
                <constraints nullable="false"/>
            </column>
            <column name="modified_date_time" type="TIMESTAMP WITH TIME ZONE">
                <constraints nullable="false"/>
            </column>
        </createTable>
        <addPrimaryKey columnNames="id" constraintName="pk_round" tableName="round"/>
        <addForeignKeyConstraint constraintName="fk_round_poker_table_id" onDelete="CASCADE"
                                 baseTableName="round" baseColumnNames="poker_table_id"
                                 referencedTableName="poker_table" referencedColumnNames="id"/>
    </changeSet>

    <changeSet author="tbigg" id="4">
        <createTable tableName="player_session">
            <column name="id" type="uuid">
                <constraints nullable="false"/>
            </column>
            <column name="user_id" type="uuid">
                <constraints nullable="false"/>
            </column>
            <column name="poker_table_id" type="uuid"/>
            <column name="round_id" type="uuid"/>
            <column name="position" type="int"/>
            <column name="dealer" type="boolean" defaultValue="0"/>
            <column name="current" type="boolean" defaultValue="0"/>
            <column name="active" type="boolean" defaultValue="0"/>
            <column name="funds" type="decimal(19,2)"/>
            <column name="session_state" type="text"/>
            <column name="connection_type" type="text"/>
            <column name="created_date_time" type="TIMESTAMP WITH TIME ZONE">
                <constraints nullable="false"/>
            </column>
            <column name="modified_date_time" type="TIMESTAMP WITH TIME ZONE">
                <constraints nullable="false"/>
            </column>
        </createTable>
        <addPrimaryKey columnNames="id" constraintName="pk_player_session" tableName="player_session"/>
        <addForeignKeyConstraint constraintName="fk_player_session_user_id" onDelete="CASCADE"
                                 baseTableName="player_session" baseColumnNames="user_id"
                                 referencedTableName="app_user" referencedColumnNames="id"/>
        <addForeignKeyConstraint constraintName="fk_player_session_poker_table_id" onDelete="CASCADE"
                                 baseTableName="player_session" baseColumnNames="poker_table_id"
                                 referencedTableName="poker_table" referencedColumnNames="id"/>
    </changeSet>

    <changeSet author="tbigg" id="5">
        <createTable tableName="hand">
            <column name="id" type="uuid">
                <constraints nullable="false"/>
